"use client"

import { useEffect, useState, useCallback } from "react"
import { useRouter } from "next/navigation"
import { Button } from "@/components/ui/button"
import { Input, Select, Label, Textarea } from "@/components/ui/input"
import { Card, CardContent } from "@/components/ui/card"
import { fetchModels, fetchSkills, fetchAccounts, createTask, createSession } from "@/lib/api"
import type { Model, Skill, AccountSummary } from "@/types"
import { Sparkles, Loader2 } from "lucide-react"
import {
  TagInputBar,
  TagSelector,
  getEmptySelection,
} from "@/components/tasks/tag-selector"
import { ToastContainer } from "@/components/ui/toast"
import { buildPrompt } from "@/lib/tags"
import type { TagCategoryKey } from "@/lib/tags"

export default function NewTaskPage() {
  const router = useRouter()
  const [models, setModels] = useState<Model[]>([])
  const [skills, setSkills] = useState<Skill[]>([])
  const [accounts, setAccounts] = useState<AccountSummary[]>([])
  const [loading, setLoading] = useState(true)
  const [submitting, setSubmitting] = useState(false)
  const [error, setError] = useState("")

  const [topic, setTopic] = useState("")
  const [platform, setPlatform] = useState("fanqie")
  const [skillId, setSkillId] = useState("")
  const [modelId, setModelId] = useState("deepseek/deepseek-chat")
  const [selectedAccountIds, setSelectedAccountIds] = useState<string[]>([])
  const [selectedTags, setSelectedTags] = useState(getEmptySelection())
  const [tagSelectorOpen, setTagSelectorOpen] = useState(false)

  const loadResources = useCallback(async () => {
    setLoading(true)
    try {
      const [m, s, a] = await Promise.all([
        fetchModels(),
        fetchSkills(),
        fetchAccounts(),
      ])
      setModels(m)
      setSkills(s)
      setAccounts(Array.isArray(a) ? a : [])
      if (s.length > 0) setSkillId(s[0].skill_id)
    } catch {
      setError("加载资源失败，请确认后端服务已启动")
    } finally {
      setLoading(false)
    }
  }, [])

  useEffect(() => {
    loadResources()
  }, [loadResources])

  const handleRemoveTag = (categoryKey: TagCategoryKey, tagId: string) => {
    setSelectedTags((prev) => ({
      ...prev,
      [categoryKey]: prev[categoryKey].filter((t) => t.id !== tagId),
    }))
  }

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault()
    if (selectedTags.main.length === 0) {
      setError("请选择作品标签的主分类")
      return
    }
    if (!skillId) {
      setError("请选择写作风格")
      return
    }

    setSubmitting(true)
    setError("")

    try {
      const prompt = buildPrompt(selectedTags, topic)
      const taskResp = await createTask({
        topic: prompt,
        platform,
        skill_id: skillId,
        model: modelId,
        account_ids: selectedAccountIds,
      })
      const taskId = taskResp.data?.task_id
      if (!taskId) throw new Error("创建任务失败：未返回 task_id")
      const session = await createSession({
        task_id: taskId,
        skillId,
        model: modelId,
        topic: prompt,
      })
      router.push(`/tasks/${taskId}?sid=${session.session_id}&platform=${platform}`)
    } catch (err) {
      setError(err instanceof Error ? err.message : "创建任务失败")
    } finally {
      setSubmitting(false)
    }
  }

  if (loading) {
    return (
      <div className="flex items-center justify-center h-[60vh]">
        <Loader2 className="w-6 h-6 animate-spin text-primary" />
      </div>
    )
  }

  return (
    <div className="max-w-2xl mx-auto">
      <div className="mb-6">
        <h1 className="text-xl font-semibold text-foreground page-title-underline inline-block">
          新建创作任务
        </h1>
        <p className="text-[13px] text-muted-foreground mt-1.5">
          选择作品标签并补充创作主题，AI 将自动为你生成内容
        </p>
      </div>

      <Card>
        <CardContent className="pt-6">
          <form onSubmit={handleSubmit} className="space-y-5">
            <div>
              <Label>作品标签 *</Label>
              <TagInputBar
                selectedTags={selectedTags}
                onRemoveTag={handleRemoveTag}
                onClick={() => setTagSelectorOpen(true)}
              />
            </div>

            <div>
              <Label>创作主题</Label>
              <Textarea
                value={topic}
                onChange={(e) => setTopic(e.target.value)}
                placeholder="请输入补充描述（选填）"
                rows={3}
                maxLength={500}
              />
              <p className="text-xs text-muted-foreground mt-1">
                {topic.length}/500
              </p>
            </div>

            <div className="grid grid-cols-2 gap-4">
              <div>
                <Label>发布平台</Label>
                <Select value={platform} onChange={(e) => setPlatform(e.target.value)}>
                  <option value="xhs">小红书</option>
                  <option value="wechat">微信公众号</option>
                  <option value="fanqie">番茄小说</option>
                  <option value="yuewen">阅文</option>
                  <option value="zhulang">逐浪网</option>
                </Select>
              </div>

              <div>
                <Label>AI 模型</Label>
                <Select value={modelId} onChange={(e) => setModelId(e.target.value)}>
                  {models.map((m) => (
                    <option key={m.id} value={m.id}>
                      {m.name}
                    </option>
                  ))}
                </Select>
              </div>
            </div>

            <div>
              <Label>写作风格</Label>
              <div className="grid grid-cols-2 gap-3">
                {skills.map((s) => (
                  <button
                    key={s.skill_id}
                    type="button"
                    onClick={() => setSkillId(s.skill_id)}
                    className={`text-left p-3 rounded-lg border transition-all ${
                      skillId === s.skill_id
                        ? "border-primary bg-primary/5 text-primary"
                        : "border-border bg-white hover:border-primary/40 text-foreground"
                    }`}
                  >
                    <p className="text-sm font-medium">
                      {s.name}
                    </p>
                    <p className="text-xs text-muted-foreground mt-1 line-clamp-2">
                      {s.description}
                    </p>
                  </button>
                ))}
              </div>
            </div>

            {accounts.length > 0 && (
              <div>
                <Label>发布账号（可选）</Label>
                <div className="flex flex-wrap gap-2">
                  {accounts.map((acc) => (
                    <button
                      key={acc.account_id}
                      type="button"
                      onClick={() =>
                        setSelectedAccountIds((prev) =>
                          prev.includes(acc.account_id)
                            ? prev.filter((id) => id !== acc.account_id)
                            : [...prev, acc.account_id]
                        )
                      }
                      className={`px-3 py-1.5 rounded-lg text-xs font-medium border transition-all ${
                        selectedAccountIds.includes(acc.account_id)
                          ? "border-primary bg-primary/5 text-primary"
                          : "border-border text-muted-foreground hover:text-foreground"
                      }`}
                    >
                      {acc.platform} · {acc.masked_display}
                    </button>
                  ))}
                </div>
              </div>
            )}

            {error && (
              <div className="p-3 rounded-lg bg-destructive/8 border border-destructive/20 text-destructive text-sm">
                {error}
              </div>
            )}

            <Button
              type="submit"
              size="xl"
              disabled={submitting}
            >
              {submitting ? (
                <>
                  <Loader2 className="w-4 h-4 animate-spin" />
                  正在创建...
                </>
              ) : (
                <>
                  <Sparkles size={18} />
                  开始创作
                </>
              )}
            </Button>
          </form>
        </CardContent>
      </Card>

      <TagSelector
        open={tagSelectorOpen}
        selectedTags={selectedTags}
        onConfirm={(tags) => {
          setSelectedTags(tags)
          setTagSelectorOpen(false)
        }}
        onClose={() => setTagSelectorOpen(false)}
      />

      <ToastContainer />
    </div>
  )
}
